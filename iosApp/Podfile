source 'https://cdn.cocoapods.org'
platform :ios, '15.6'
use_frameworks!

FIREBASE_VERSION = '11.14.0'

def add_common_pods
  pod 'FirebaseCore', FIREBASE_VERSION
  # Note: FirebasePerformance must remain here even though it is declared via KMM pod():
  # it is a dynamic framework that DYLD must resolve at runtime on the simulator;
  # KMM pod() declarations alone do not place the .framework into the simulator products dir.
  pod 'FirebaseAnalytics', FIREBASE_VERSION
  pod 'FirebasePerformance', FIREBASE_VERSION
  pod 'FirebaseMessaging', FIREBASE_VERSION
  pod 'Mixpanel', '5.0.8'
  pod 'FBSDKCoreKit', '18.0.0'
end

target 'Yral' do
  add_common_pods
  pod 'iosSharedUmbrella', :path => '../iosSharedUmbrella'
end

target 'YralTests' do
  inherit! :search_paths
  add_common_pods
  pod 'iosSharedUmbrella', :path => '../iosSharedUmbrella'
end

target 'Yral-Staging' do
  add_common_pods
  pod 'iosSharedUmbrella', :path => '../iosSharedUmbrella'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      if target.name != 'iosSharedUmbrella'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.6'
      end
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
      config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
    end
  end
end
